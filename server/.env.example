# ─── Tencent Cloud TRTC / Chat ────────────────────────────────────────────────
# SDKAppId from https://console.trtc.io or https://console.tim.qq.com
SDK_APP_ID=20026228

# SecretKey for UserSig generation (from the same console page as SDK_APP_ID)
SECRET_KEY=your_secret_key_here

# ─── Tencent Cloud API credentials ───────────────────────────────────────────
# From https://console.cloud.tencent.com/cam/capi
CLOUD_SECRET_ID=your_cloud_secret_id_here
CLOUD_SECRET_KEY=your_cloud_secret_key_here

# ─── Server settings ─────────────────────────────────────────────────────────
PORT=3000

# Comma-separated list of allowed CORS origins (no trailing slash)
# e.g. http://localhost:8080,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
