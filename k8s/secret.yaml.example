# Secret for server environment variables
# Usage:
#   1. Copy this file: cp k8s/secret.yaml.example k8s/secret.yaml
#   2. Fill in your base64-encoded values (see below)
#   3. Apply: kubectl apply -f k8s/secret.yaml
#
# How to base64-encode a value:
#   echo -n "your_value" | base64
#
# IMPORTANT: k8s/secret.yaml is in .gitignore — never commit the real file.
#
apiVersion: v1
kind: Secret
metadata:
  name: trtc-server-secret
  namespace: trtc-demo
type: Opaque
data:
  SDK_APP_ID: <base64_encoded_sdk_app_id>
  SECRET_KEY: <base64_encoded_trtc_secret_key>
  CLOUD_SECRET_ID: <base64_encoded_cloud_secret_id>
  CLOUD_SECRET_KEY: <base64_encoded_cloud_secret_key>
