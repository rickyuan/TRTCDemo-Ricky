<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ── Remote video (full screen) ─────────────────────────────────────── -->
    <com.tencent.rtmp.ui.TXCloudVideoView
        android:id="@+id/viewRemoteVideo"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Remote placeholder -->
    <LinearLayout
        android:id="@+id/tvRemotePlaceholder"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#111111">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📞"
            android:textSize="56sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_waiting"
            android:textColor="#8A8FA8"
            android:textSize="16sp" />

    </LinearLayout>

    <!-- ── Local video (Picture-in-Picture) ───────────────────────────────── -->
    <FrameLayout
        android:layout_width="110dp"
        android:layout_height="165dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:background="#1A1A1A"
        android:elevation="4dp">

        <com.tencent.rtmp.ui.TXCloudVideoView
            android:id="@+id/viewLocalVideo"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </FrameLayout>

    <!-- ── Status bar (top-left) ──────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="top|start"
        android:layout_margin="16dp">

        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvUserId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#CCCCCC"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvRoomId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#AAAAAA"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvCallStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_connecting"
            android:textColor="#8A8FA8"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- ── Subtitle overlay ─────────────────────────────────────────────── -->
    <!-- elevation=8dp ensures this renders above the controls panel (which has no elevation). -->
    <!-- In FrameLayout, later children are drawn on top, but elevation overrides that order.  -->
    <LinearLayout
        android:id="@+id/subtitleOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="264dp"
        android:paddingHorizontal="20dp"
        android:orientation="vertical"
        android:gravity="center"
        android:elevation="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvSubtitleOriginal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#CC000000"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:layout_gravity="center"
            android:maxWidth="340dp" />

        <TextView
            android:id="@+id/tvSubtitleTranslation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#CC000000"
            android:paddingHorizontal="12dp"
            android:paddingVertical="5dp"
            android:textColor="#FFEE88"
            android:textSize="13sp"
            android:layout_gravity="center"
            android:layout_marginTop="4dp"
            android:maxWidth="340dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvSubtitleTranslationId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#CC000000"
            android:paddingHorizontal="12dp"
            android:paddingVertical="5dp"
            android:textColor="#88DDFF"
            android:textSize="13sp"
            android:layout_gravity="center"
            android:layout_marginTop="4dp"
            android:maxWidth="340dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- ── Controls ────────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:orientation="vertical"
        android:layout_marginBottom="32dp"
        android:paddingHorizontal="16dp">

        <!-- Row 1: Resolution picker -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_resolution"
                android:textColor="#CCCCCC"
                android:textSize="13sp" />

            <Spinner
                android:id="@+id/spinnerResolution"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:backgroundTint="#444444" />

        </LinearLayout>

        <!-- Button panel: 2 rows -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#66000000"
            android:paddingHorizontal="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <!-- Row 2a: Mute | Cam | Hang Up -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <Button
                    android:id="@+id/btnToggleMic"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:layout_margin="5dp"
                    android:text="@string/btn_mute"
                    android:textSize="13sp"
                    android:backgroundTint="#333333"
                    android:textColor="#FFFFFF"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/btnToggleCam"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:layout_margin="5dp"
                    android:text="@string/btn_cam_off"
                    android:textSize="13sp"
                    android:backgroundTint="#333333"
                    android:textColor="#FFFFFF"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/btnHangup"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:layout_margin="5dp"
                    android:text="@string/btn_hang_up"
                    android:textSize="13sp"
                    android:backgroundTint="#E5363B"
                    android:textColor="#FFFFFF"
                    android:stateListAnimator="@null" />

            </LinearLayout>

            <!-- Row 2b: Switch Cam | Share Screen -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/btnSwitchCam"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_margin="5dp"
                    android:text="@string/btn_switch_rear"
                    android:textSize="13sp"
                    android:backgroundTint="#333333"
                    android:textColor="#FFFFFF"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/btnScreenShare"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_margin="5dp"
                    android:text="@string/btn_share_screen"
                    android:textSize="13sp"
                    android:backgroundTint="#1A5276"
                    android:textColor="#FFFFFF"
                    android:stateListAnimator="@null" />

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</FrameLayout>
